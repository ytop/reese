# Model configuration (OpenAI-compatible endpoint)
MODEL_API_KEY=sk-your-key-here
MODEL_API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# Think model (optional — for /think command, can be different provider)
THINK_MODEL_API_KEY=
THINK_MODEL_API_BASE=
THINK_MODEL_NAME=

# Gemini integration (optional — for /gemini command in Telegram)
# OAuth token is read from ~/.gemini/oauth_creds.json (set up via gemini-cli)
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# Required only if the token expires and needs refreshing
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=

# Telegram bot (optional — only needed for telegram mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_FROM=username1,12345678
# Optional: specific chat ID to send logs to (defaults to first allowed user)
TELEGRAM_LOG_CHAT_ID=

# Discord bot (optional — fallback when Telegram is rate limited)
DISCORD_BOT_TOKEN=
DISCORD_ALLOW_FROM=user_id1,user_id2

# Agent settings
# WORKSPACE_DIR=~/.reese/workspace
MAX_ITERATIONS=50
MAX_TOKENS=8192
CONTEXT_WINDOW_TOKENS=65536
